{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "powershell -NoProfile -Command \"$input=$null; try{$raw=[Console]::In.ReadToEnd();if($raw){$input=$raw|ConvertFrom-Json}}catch{};$cwd=if($input){$input.workspace.current_dir}else{(Get-Location).Path};$mod='';$t=$cwd;while($t-and$t.Length-gt3){if(Test-Path(Join-Path$t'go.mod')){$mod=Split-Path$t-Leaf;break};$t=Split-Path$t-Parent};$rel='';if($mod-and$cwd.StartsWith($t,'OrdinalIgnoreCase')){$r=$cwd.Substring($t.Length).TrimStart('\\','/');if($r){$rel=\"/$r\"}};$br='';try{$b=&git -C$cwd branch --show-current 2>$null;if($LASTEXITCODE-eq0-and$b){$br=$b.Trim()}}catch{};$pr='';if($input.pr.number){$st=if($input.pr.review_state){\" [$($input.pr.review_state)]\"}else{''};$pr=\" PR#$($input.pr.number)$st\"};$out=@();if($mod){$out+=\"$mod$rel\"}else{$out+=(Split-Path$cwd-Leaf)};if($br){$out+=\"[$br]\"};if($pr){$out+=$pr};Write-Output($out-join' ')\""
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "mcp__mcp-atlassian-http__confluence_get_page",
      "mcp__mcp-atlassian-http__jira_get_issue",
      "Read(**)",
      "Bash(awk:*)",
      "Bash(bash:*)",
      "Bash(brew install:*)",
      "Bash(cd:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(export:*)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(perl:*)",
      "Bash(sed:*)",
      "Bash(touch:*)",
      "mcp__mcp_server_mysql__connect_db",
      "mcp__mcp_server_mysql__query",
      "mcp__mcp_server_mysql__list_tables",
      "mcp__mcp_server_mysql__describe_table",
      "mcp__mcp-atlassian-http__confluence_update_page",
      "Bash(touch *)",
      "Bash(git *)",
      "Bash(go *)",
      "Bash(Sort-Object)",
      "Bash(make build *)",
      "PowerShell(Get-Command *)",
      "PowerShell(Set-Content *)",
      "PowerShell(go build *)",
      "PowerShell(go *)",
      "PowerShell(go test *)",
      "PowerShell(go vet *)",
      "Skill(fewer-permission-prompts)",
      "Bash(python3 *)",
      "Bash(git rm *)",
      "Bash(git reset *)",
      "Bash(python -c ' *)",
      "Skill(code-review)"
    ],
    "deny": []
  }
}
